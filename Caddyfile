# Caddyfile for body.aerogelovepanice.com — deploy on VPS host (not in container).
#
# Put at /etc/caddy/Caddyfile or include from there, then:
#   sudo systemctl reload caddy
#
# Cloudflare DNS for body.aerogelovepanice.com points at this VPS in
# DNS-only (grey cloud) mode so Caddy can issue Let's Encrypt certs
# without Cloudflare's edge stripping them.

body.aerogelovepanice.com {
    # Device WebSocket. wss://body/ws — note Caddy needs explicit ws upgrade
    # config; the @websockets matcher + reverse_proxy is the standard idiom.
    @websockets {
        path /ws
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @websockets {
        reverse_proxy 127.0.0.1:8765
    }

    # TTS audio pull. Device fetches https://body/audio/<file>.wav after we
    # POST it the URL via WS. Caddy strips nothing — media_server expects
    # the /audio/<filename> path verbatim.
    handle /audio/* {
        reverse_proxy 127.0.0.1:8766
    }

    # Recording + photo uploads. Same media server.
    handle /upload/* {
        reverse_proxy 127.0.0.1:8766
    }

    # MCP streamable-http transport. Claude clients (Code/Desktop/browser)
    # hit https://body/mcp. The FastMCP streamable_http_app listens on the
    # path `/mcp` by default — do NOT strip the prefix or the upstream
    # router 404s. (This bit me on first deploy; leaving the comment as a
    # tripwire for anyone tempted to "clean up" with handle_path.)
    #
    # Why a named matcher with explicit alternatives instead of `handle /mcp*`:
    # the latter doesn't match the bare `/mcp` path (no trailing slash) — it
    # only matches /mcp + at least one character. Caddy then routes /mcp to
    # the fallback handler, which returns its own response instead of
    # proxying. Listing /mcp and /mcp/* explicitly covers both forms.
    # OAuth 2.1 endpoints — claude.ai mobile/web discovers + flows through
    # these to mint a JWT bearer. Same upstream port as /mcp (FastMCP + OAuth
    # share the Starlette app). Same Host-rewrite quirk applies — uvicorn
    # would 421 on the public FQDN.
    @oauth_paths path /.well-known/oauth-* /oauth/*
    handle @oauth_paths {
        reverse_proxy 127.0.0.1:8767 {
            header_up Host {upstream_hostport}
        }
    }

    @mcp_paths path /mcp /mcp/*
    handle @mcp_paths {
        reverse_proxy 127.0.0.1:8767 {
            # Uvicorn rejects requests whose Host header doesn't match what
            # it thinks it's serving — 421 "Invalid Host header". Caddy
            # passes Host through unchanged by default, which is the public
            # FQDN; uvicorn doesn't recognize it. Rewrite to the upstream's
            # host:port so uvicorn sees a Host it considers its own.
            # aiohttp (used by media_server for /audio + /upload) doesn't
            # have this guard, which is why those paths work without this
            # workaround.
            header_up Host {upstream_hostport}
        }
    }

    # Everything else: 404 (no public root page on purpose).
    handle {
        respond "not found" 404
    }
}
