# Claude's body MCP — gateway env vars.
# Copy to .env and fill in. Don't commit .env.

# ── ElevenLabs (TTS + STT) ─────────────────────────────────────────
# Voice Panice designed in ElevenLabs for stackchan.
ELEVENLABS_VOICE_ID=ObQz2Bok60YT5RSuUln3
# API key — also tracked in Panice's local credentials doc per [[user_credential_habit]].
ELEVENLABS_API_KEY=

# Optional: override model. eleven_turbo_v2_5 = fastest, multilingual.
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_STT_MODEL=scribe_v1

# ── Device auth (WS + media upload) ────────────────────────────────
# Bearer token the device sends in WS upgrade Authorization header
# AND in HTTP upload Authorization header. Reused from old body-mcp .env.
STACKCHAN_TOKEN=

# ── Ports ──────────────────────────────────────────────────────────
# Device WS port (Caddy reverse-proxies wss://body/ws -> this).
WS_PORT=8765
# Media HTTP port (Caddy reverse-proxies https://body/audio/* -> this,
# and https://body/upload/* -> this).
MEDIA_PORT=8766
# MCP streamable-http port (Caddy reverse-proxies https://body/mcp/* -> this).
MCP_PORT=8767

# ── Public base URL for device-fetched audio ──────────────────────
# Device pulls TTS WAVs from this base. Prod: https://body.aerogelovepanice.com
PUBLIC_BASE_URL=https://body.aerogelovepanice.com

# ── OAuth 2.1 (for claude.ai mobile/web Integrations) ─────────────
# HS256 secret for signing access + refresh JWTs. Generate fresh with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Keep ≥32 bytes (RFC 7518 §3.2 requires 256+ bits for HS256).
# If unset, gateway falls back to a process-lifetime random — tokens
# die on restart, requiring re-auth. Fine for dev, bad for prod.
OAUTH_JWT_SECRET=

# ── Misc ───────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LISTEN_DEFAULT_MS=5000
# AUDIO_DIR=/tmp/stackchan_audio
# CAPTURE_DIR=~/.stackchan/captures
